    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "上游算子的输出引用"
    },
    {
      "name": "path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "文件保存路径"
    },
    {
      "name": "overwrite",
      "role": "data",
      "type": "bool",
      "required": false,
      "default": false,
      "description": "是否允许覆盖已有文件"
    }
  ],
  "output_params": [],
  "command_template": []
}
