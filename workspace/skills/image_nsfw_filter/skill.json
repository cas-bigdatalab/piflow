{
  "name": "image_nsfw_filter",
  "version": "1.0.0",
  "description": "图像NSFW内容检测过滤器。过滤器保留图像具有低nsfw分数的样本。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到图片安全检测、NSFW过滤、不良内容过滤、图片审核、图像内容过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_image_nsfw_filter.py",
  "entrypoint": "python scripts/run_image_nsfw_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径（JSON/JSONL格式）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径（JSONL格式）"
    },
    {
      "name": "hf_nsfw_model",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "HuggingFace上的NSFW检测模型",
      "default": "Falconsai/nsfw_image_detection"
    },
    {
      "name": "max_score",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大NSFW分数阈值（0-1之间，低于此值保留）",
      "default": 0.5
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any/all）",
      "default": "any"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "image_nsfw_filter_output.jsonl",
      "description": "过滤后的JSONL文件，包含NSFW分数低于阈值的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--hf_nsfw_model",
    "{hf_nsfw_model}",
    "--max_score",
    "{max_score}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}