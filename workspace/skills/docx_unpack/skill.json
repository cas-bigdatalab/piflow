{
  "name": "docx_unpack",
  "version": "1.0.0",
  "description": "将DOCX文件解压为XML目录",
  "language": "python",
  "script_path": "scripts/run_docx_unpack.py",
  "entrypoint": "python scripts/run_docx_unpack.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "docx_file",
      "required": false,
      "description": "输入DOCX文件路径"
    },
    {
      "name": "output_dir",
      "role": "output_data",
      "type": "directory",
      "required": false,
      "description": "输出目录路径"
    },
    {
      "name": "merge_runs",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否合并相邻的文本运行",
      "default": true
    }
  ],
  "output_params": [
    {
      "name": "output_dir",
      "role": "output_data",
      "type": "directory",
      "default": "docx_unpack_output",
      "description": "解压后的XML目录"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_dir",
    "{output_dir}",
    "--merge_runs",
    "{merge_runs}"
  ]
}