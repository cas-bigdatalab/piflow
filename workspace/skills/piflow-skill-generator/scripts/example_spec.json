{
  "name": "example_utf8_mapper",
  "title": "Example UTF-8 Mapper",
  "description": "示例UTF-8映射器，用于验证中文元数据和脚本生成。",
  "version": "1.0.0",
  "triggers": ["中文处理", "UTF-8技能生成", "示例映射"],
  "category": "mapper",
  "tag": "示例",
  "language": "python",
  "trigger_conditions": [
    "当任务需要验证 PiFlow 技能生成器的 UTF-8 中文处理时使用此技能。"
  ],
  "core_features": [
    "读取 JSON 输入文件",
    "按指定文本字段执行示例映射",
    "将处理结果写入 JSON 输出文件"
  ],
  "processing_logic": [
    "读取 input_path 指向的 JSON 文件",
    "定位 text_key 指定的文本字段",
    "写入 output_path 指向的输出文件"
  ],
  "supported_formats": ["JSON"],
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "default": "text",
      "description": "文本字段名"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "json_file",
      "description": "处理后的JSON文件"
    }
  ],
  "script": {
    "path": "scripts/run_example_utf8_mapper.py"
  },
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--text_key",
    "{text_key}"
  ],
  "dependencies": ["Python 3.x"],
  "output_format": [
    {
      "text": "处理后的文本内容"
    }
  ],
  "examples": [
    {
      "title": "基本调用",
      "command": "python scripts/run_example_utf8_mapper.py --input_path input.json --output_path output.json"
    }
  ]
}
