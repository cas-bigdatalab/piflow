{
  "name": "keyword_extractor",
  "version": "1.0.0",
  "description": "关键词提取标注工具。读取包含文本字段的表格或JSONL语料，为每条记录提取核心关键词并写入新增关键词字段。当用户提到关键词提取、关键词抽取、文本关键词、标签提取等需求时使用此skill。不负责按预置领域关键词库做相关性筛选、文本清洗、分词结果展开或章节切分。",
  "language": "python",
  "script_path": "scripts/run_keyword_extractor.py",
  "entrypoint": "python scripts/run_keyword_extractor.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "text_field",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "文本字段名"
    },
    {
      "name": "label_field",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "输出关键词字段名",
      "default": "keywords"
    },
    {
      "name": "topk",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "提取关键词数量",
      "default": "5"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "csv_file",
      "default": "keyword_extractor_output.csv",
      "description": "关键词提取后的数据文件"
    }
  ],
  "tag": "增强",
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--text_field",
    "{text_field}",
    "--label_field",
    "{label_field}",
    "--topk",
    "{topk}"
  ]
}
