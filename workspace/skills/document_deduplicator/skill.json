{
  "name": "document_deduplicator",
  "version": "1.0.0",
  "description": "文档去重工具。使用精确匹配（MD5哈希）在文档级别删除重复的样本。 当用户提到文档去重、删除重复文档、样本去重、文本去重、去除重复内容、 清洗重复数据、整理文档集合等需求时使用此skill。 即使用户没有明确说出\"去重\"，只要任务涉及从多个文档中识别和删除重复内容， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/document_deduplicator.py",
  "entrypoint": "python scripts/document_deduplicator.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径（支持json, txt）"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径（支持json, txt）"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    },
    {
      "name": "lowercase",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否将文本转为小写进行比对",
      "default": false
    },
    {
      "name": "ignore_non_character",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否忽略非字母字符（空格、数字、标点）",
      "default": false
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "json_file",
      "default": "document_deduplicator_output.json",
      "description": "去重后的文件（json或txt格式）"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--text_key",
    "{text_key}",
    "--lowercase",
    "{lowercase}",
    "--ignore_non_character",
    "{ignore_non_character}"
  ]
}