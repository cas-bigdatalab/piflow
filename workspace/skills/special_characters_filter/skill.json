{
  "name": "special_characters_filter",
  "version": "1.0.0",
  "description": "特殊字符过滤器。过滤器将具有特殊字符比率的样品保持在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到特殊字符过滤、特殊字符比例过滤、文本特殊字符检测、清理乱码文本等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_special_characters_filter.py",
  "entrypoint": "python scripts/run_special_characters_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "min_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小特殊字符比例",
      "default": 0.0
    },
    {
      "name": "max_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大特殊字符比例",
      "default": 0.25
    },
    {
      "name": "batch_size",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "批处理大小",
      "default": 1
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "special_characters_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--min_ratio",
    "{min_ratio}",
    "--max_ratio",
    "{max_ratio}",
    "--batch_size",
    "{batch_size}",
    "--num_proc",
    "{num_proc}"
  ]
}