{
  "name": "duplicate_detector_exact",
  "version": "1.0.0",
  "description": "精确去重工具。使用pandas精确匹配检测并处理数据集中的完全重复记录。当用户提到精确去重、完全重复检测时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_duplicate_detector_exact.py",
  "entrypoint": "python scripts/run_duplicate_detector_exact.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "subset",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "用于判断重复的字段列表，逗号分隔",
      "default": ""
    },
    {
      "name": "keep",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "保留策略（first/last/none/mark）",
      "default": "first"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "csv_file",
      "default": "duplicate_detector_exact_output.csv",
      "description": "去重后的数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--subset",
    "{subset}",
    "--keep",
    "{keep}"
  ],
  "tag": "去重"
}