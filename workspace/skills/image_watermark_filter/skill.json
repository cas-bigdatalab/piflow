{
  "name": "image_watermark_filter",
  "version": "1.0.0",
  "description": "图像水印过滤器。过滤器以保持其图像没有水印的样本具有高概率。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到图像水印检测、图片无水印过滤、水印去除、检测图片水印等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_image_watermark_filter.py",
  "entrypoint": "python scripts/run_image_watermark_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径（JSON/JSONL格式）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径（JSONL格式）"
    },
    {
      "name": "hf_watermark_model",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "HuggingFace上的水印检测模型",
      "default": "amrul-hzz/watermark_detector"
    },
    {
      "name": "prob_threshold",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "水印概率阈值（0-1之间，低于此值保留）",
      "default": 0.8
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any/all）",
      "default": "any"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "image_watermark_filter_output.jsonl",
      "description": "过滤后的JSONL文件，包含无水印或水印概率低于阈值的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--hf_watermark_model",
    "{hf_watermark_model}",
    "--prob_threshold",
    "{prob_threshold}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}