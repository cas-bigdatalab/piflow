{
  "name": "ray_video_deduplicator",
  "version": "1.0.0",
  "description": "Ray分布式视频去重工具。使用精确匹配（MD5哈希）在文档级别删除重复视频，基于Ray分布式框架。 当用户提到视频去重、删除重复视频、分布式去重、大规模视频去重等需求时使用此skill。 即使用户没有明确说出\"Ray\"或\"分布式\"，只要任务涉及大规模视频去重处理， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_ray_video_deduplicator.py",
  "entrypoint": "python scripts/run_ray_video_deduplicator.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "backend",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "分布式后端类型（ray_actor/redis）",
      "default": "ray_actor"
    },
    {
      "name": "redis_address",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "Redis服务器地址",
      "default": "redis://localhost:6379"
    },
    {
      "name": "video_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "视频字段的键名",
      "default": "videos"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "ray_video_deduplicator_output.jsonl",
      "description": "去重后的JSON文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--backend",
    "{backend}",
    "--redis_address",
    "{redis_address}",
    "--video_key",
    "{video_key}",
    "--text_key",
    "{text_key}"
  ]
}