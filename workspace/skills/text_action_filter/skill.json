{
  "name": "text_action_filter",
  "version": "1.0.0",
  "description": "文本动作词过滤器。过滤以保留文本中包含操作的文本。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到动作词过滤、动词检测、文本动作过滤、文本操作词过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_text_action_filter.py",
  "entrypoint": "python scripts/run_text_action_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "lang",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "语言代码（en 或 zh）",
      "default": "en"
    },
    {
      "name": "min_action_num",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最小动作词数量",
      "default": 1
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "text_action_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--lang",
    "{lang}",
    "--min_action_num",
    "{min_action_num}",
    "--num_proc",
    "{num_proc}"
  ]
}