{
  "name": "mixture_formatter",
  "version": "1.0.0",
  "description": "混合格式化器。该类通过从每个数据集中随机选择样本并合并它们来混合多个数据集，然后将合并的数据集导出为新的混合数据集。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到混合数据集、合并多个数据集、数据集混合、数据融合等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_mixture_formatter.py",
  "entrypoint": "python scripts/run_mixture_formatter.py",
  "input_params": [
    {
      "name": "dataset_path",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "数据集路径，支持带权重格式（如 \"0.7 path1 0.3 path2\"）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSONL文件路径"
    },
    {
      "name": "suffixes",
      "role": "data",
      "type": "list",
      "required": false,
      "description": "指定后缀列表"
    },
    {
      "name": "text_keys",
      "role": "data",
      "type": "list",
      "required": false,
      "description": "文本字段名列表",
      "default": "['text']"
    },
    {
      "name": "add_suffix",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否添加文件后缀信息",
      "default": false
    },
    {
      "name": "max_samples",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "混合数据集最大样本数"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "mixture_formatter_output.jsonl",
      "description": "混合后的JSONL数据集文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--dataset_path",
    "{dataset_path}",
    "--output_path",
    "{output_path}",
    "--suffixes",
    "{suffixes}",
    "--text_keys",
    "{text_keys}",
    "--add_suffix",
    "{add_suffix}",
    "--max_samples",
    "{max_samples}",
    "--num_proc",
    "{num_proc}"
  ]
}