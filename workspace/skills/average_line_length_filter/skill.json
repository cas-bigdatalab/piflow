{
  "name": "average_line_length_filter",
  "version": "1.0.0",
  "description": "平均行长度过滤器。过滤文本平均行长度不在指定范围内的样本。 当用户提到行长度过滤、平均行长度、文本行长度筛选、按行筛选等需求时使用此skill。 即使用户没有明确说出\"平均行长度\"，只要任务涉及根据文本中每行的平均长度来筛选数据， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_average_line_length_filter.py",
  "entrypoint": "python scripts/run_average_line_length_filter.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "min_len",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小平均行长度",
      "default": 10
    },
    {
      "name": "max_len",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大平均行长度（默认无限制）"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "json_file",
      "default": "average_line_length_filter_output.json",
      "description": "过滤后的JSON文件，包含平均行长度在指定范围内的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--min_len",
    "{min_len}",
    "--max_len",
    "{max_len}",
    "--text_key",
    "{text_key}"
  ]
}