{
  "name": "Pi_DataSorting",
  "version": "1.0.0",
  "description": "数据排序工具。读取结构化数据文件，根据指定字段进行升序或降序排序，最后输出为相同格式的文件。 当用户提到数据排序、升序排列、降序排列、按某字段排序等需求时使用此skill。 即使用户没有明确说出\"排序\"，只要任务涉及对数据进行排序，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/Pi_DataSorting.py",
  "entrypoint": "python scripts/Pi_DataSorting.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径（支持CSV/TSV/Excel等）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径（排序后的文件）"
    },
    {
      "name": "id_field_name",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "排序字段名，支持多字段用逗号分隔"
    },
    {
      "name": "sort_order",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "排序方式（asc升序/desc降序）",
      "default": "asc"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "Pi_DataSorting_output.csv",
      "description": "排序后的结构化数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--id_field_name",
    "{id_field_name}",
    "--sort_order",
    "{sort_order}"
  ]
}