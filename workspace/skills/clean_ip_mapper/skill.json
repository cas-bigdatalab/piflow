{
  "name": "clean_ip_mapper",
  "version": "1.0.0",
  "description": "清除文本示例中的IPv4和IPv6地址。当用户提到清理IP、删除IP地址、去除IP、清理网络地址等需求时使用此skill。 即使用户没有明确说出\"IP\"，只要任务涉及从文本中删除或替换IP地址，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_clean_ip_mapper.py",
  "entrypoint": "python scripts/run_clean_ip_mapper.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "repl",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "替换字符串（默认为空，即删除）",
      "default": ""
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "json_file",
      "default": "clean_ip_mapper_output.json",
      "description": "清理IP地址后的JSON文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--repl",
    "{repl}"
  ]
}