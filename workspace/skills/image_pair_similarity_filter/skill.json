{
  "name": "image_pair_similarity_filter",
  "version": "1.0.0",
  "description": "图像对相似度过滤器。过滤器将图像之间具有相似性的图像对保持在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到图像相似度检测、图像对过滤、双图相似度、图片相似度筛选、图像pair过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_image_pair_similarity_filter.py",
  "entrypoint": "python scripts/run_image_pair_similarity_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径（JSON/JSONL格式）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径（JSONL格式）"
    },
    {
      "name": "hf_clip",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "HuggingFace上的CLIP模型",
      "default": "openai/clip-vit-base-patch32"
    },
    {
      "name": "min_score",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小相似度分数",
      "default": 0.1
    },
    {
      "name": "max_score",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大相似度分数",
      "default": 1.0
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any/all）",
      "default": "any"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "image_pair_similarity_filter_output.jsonl",
      "description": "过滤后的JSONL文件，包含图像对相似度在指定范围内的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--hf_clip",
    "{hf_clip}",
    "--min_score",
    "{min_score}",
    "--max_score",
    "{max_score}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}