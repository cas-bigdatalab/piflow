{
  "name": "pdf_table_extract",
  "version": "1.0.0",
  "description": "从PDF文件中提取表格数据，输出为JSON格式。当用户需要从PDF中提取表格时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_pdf_table_extract.py",
  "entrypoint": "python scripts/run_pdf_table_extract.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入PDF文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "pages",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "页码范围，如\"1-3,5\"（可选，默认全部页面）"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "json_file",
      "default": "pdf_table_extract_output.json",
      "description": "提取的表格JSON文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--pages",
    "{pages}"
  ]
}