{
  "name": "image_face_count_filter",
  "version": "1.0.0",
  "description": "图像人脸数量过滤器。过滤以保持样本的面数在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到过滤图片、识别人脸、人脸数量检测、图片人脸筛选、按人脸数量过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_image_face_count_filter.py",
  "entrypoint": "python scripts/run_image_face_count_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径（JSON/JSONL格式）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径（JSONL格式）"
    },
    {
      "name": "min_face_count",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最少人脸数量",
      "default": 1
    },
    {
      "name": "max_face_count",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最多人脸数量",
      "default": 1
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any/all）",
      "default": "any"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "image_face_count_filter_output.jsonl",
      "description": "过滤后的JSONL文件，包含人脸数量在指定范围内的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--min_face_count",
    "{min_face_count}",
    "--max_face_count",
    "{max_face_count}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}