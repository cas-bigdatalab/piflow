{
  "name": "word_repetition_filter",
  "version": "1.0.0",
  "description": "单词重复比例过滤器。过滤器将单词级n-gram重复比率的样本保持在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到单词重复过滤、文本重复比例过滤、n-gram重复过滤、清理重复内容等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_word_repetition_filter.py",
  "entrypoint": "python scripts/run_word_repetition_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "lang",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "语言代码",
      "default": "en"
    },
    {
      "name": "tokenization",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否使用分词模型",
      "default": false
    },
    {
      "name": "rep_len",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "n-gram 重复长度",
      "default": 10
    },
    {
      "name": "min_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小重复比率",
      "default": 0.0
    },
    {
      "name": "max_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大重复比率",
      "default": 0.5
    },
    {
      "name": "batch_size",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "批处理大小",
      "default": 1
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "要操作的文本字段名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "word_repetition_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--lang",
    "{lang}",
    "--tokenization",
    "{tokenization}",
    "--rep_len",
    "{rep_len}",
    "--min_ratio",
    "{min_ratio}",
    "--max_ratio",
    "{max_ratio}",
    "--batch_size",
    "{batch_size}",
    "--num_proc",
    "{num_proc}",
    "--text_key",
    "{text_key}"
  ]
}