{
  "name": "pdf_rotate",
  "version": "1.0.0",
  "description": "旋转PDF页面方向。支持顺时针90度、180度、270度旋转。当用户需要旋转PDF页面方向时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_pdf_rotate.py",
  "entrypoint": "python scripts/run_pdf_rotate.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入PDF文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出PDF文件路径"
    },
    {
      "name": "angle",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "旋转角度（90/180/270，顺时针）",
      "default": 90
    },
    {
      "name": "pages",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "页码范围，如\"1-3,5\"（可选，默认全部页面）"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "default": "pdf_rotate_output",
      "description": "旋转后的PDF文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--angle",
    "{angle}",
    "--pages",
    "{pages}"
  ]
}