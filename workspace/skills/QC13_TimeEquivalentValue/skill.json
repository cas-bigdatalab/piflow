{
  "name": "QC13_TimeEquivalentValue",
  "version": "1.0.0",
  "description": "等值检验（连续数值无变化检查）工具。读取时间序列数据，检查在连续的时间段内， 某个关键指标的数值是否长时间保持不变（久无变化检查），识别并标记异常数据，最后输出为相同格式的文件。 当用户提到等值检验、连续无变化检查、久无变化检查、时间序列恒定值检查等需求时使用此skill。 即使用户没有说出\"等值检验\"，只要任务涉及检查时间序列数据是否长时间保持不变，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/QC13_TimeEquivalentValue.py",
  "entrypoint": "python scripts/QC13_TimeEquivalentValue.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "conditions",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "检验条件，格式：字段名,连续次数，多行用换行分隔"
    },
    {
      "name": "time_field",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间字段名（用于排序判断连续性）"
    },
    {
      "name": "time_format",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间格式（如：%Y-%m-%d %H:%M:%S）"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识",
      "default": "等值异常"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识字段名",
      "default": "QC0000"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC13_TimeEquivalentValue_output.csv",
      "description": "等值检验后的结构化数据文件，带质控标识"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--conditions",
    "{conditions}",
    "--time_field",
    "{time_field}",
    "--time_format",
    "{time_format}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}