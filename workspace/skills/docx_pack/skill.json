{
  "name": "docx_pack",
  "version": "1.0.0",
  "description": "将解压的XML目录重新打包为DOCX文件",
  "language": "python",
  "script_path": "scripts/run_docx_pack.py",
  "entrypoint": "python scripts/run_docx_pack.py",
  "input_params": [
    {
      "name": "input_dir",
      "role": "data",
      "type": "directory",
      "required": false,
      "description": "解压的XML目录路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "docx_file",
      "required": false,
      "description": "输出DOCX文件路径"
    },
    {
      "name": "original",
      "role": "data",
      "type": "docx_file",
      "required": false,
      "description": "原始DOCX文件路径（可选）"
    },
    {
      "name": "validate",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否启用自动修复",
      "default": true
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "docx_file",
      "default": "docx_pack_output.docx",
      "description": "打包后的DOCX文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_dir",
    "{input_dir}",
    "--output_path",
    "{output_path}",
    "--original",
    "{original}",
    "--validate",
    "{validate}"
  ]
}