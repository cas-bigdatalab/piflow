{
  "name": "QC15_TimeChangeRange",
  "version": "1.0.0",
  "description": "最大变化范围检验工具。读取时间序列数据，检查在特定时间窗口内，数据是否出现了异常剧烈波动， 即在任意两个读数之间，其差值（变化量）的绝对值超出了预设的容忍阈值，识别并标记异常数据，最后输出为相同格式的文件。 当用户提到最大变化范围检验、变化范围检验、时间序列波动检验、窗口变化检测等需求时使用此skill。 即使用户没有说出\"最大变化范围\"，只要任务涉及检查时间序列数据在时间窗口内的变化幅度是否异常，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/QC15_TimeChangeRange.py",
  "entrypoint": "python scripts/QC15_TimeChangeRange.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "conditions",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "检验条件，格式：字段名,阈值,窗口大小，多行用换行分隔"
    },
    {
      "name": "time_field",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间字段名（用于排序判断连续性）"
    },
    {
      "name": "time_format",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间格式（如：%Y-%m-%d %H:%M:%S）"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识",
      "default": "最大变化范围检验异常"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识字段名",
      "default": "QC0000"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC15_TimeChangeRange_output.csv",
      "description": "最大变化范围检验后的结构化数据文件，带质控标识"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--conditions",
    "{conditions}",
    "--time_field",
    "{time_field}",
    "--time_format",
    "{time_format}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}