{
  "name": "token_num_filter",
  "version": "1.0.0",
  "description": "Token数量过滤器。筛选器将总令牌数的样本保留在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到token数量过滤、文本token数筛选、按token数过滤、文本分词过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_token_num_filter.py",
  "entrypoint": "python scripts/run_token_num_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "hf_tokenizer",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "HuggingFace tokenizer 模型",
      "default": "EleutherAI/pythia-6.9b-deduped"
    },
    {
      "name": "min_num",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最小 token 数量",
      "default": 10
    },
    {
      "name": "max_num",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最大 token 数量（默认不限制）"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "要操作的文本字段名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "token_num_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--hf_tokenizer",
    "{hf_tokenizer}",
    "--min_num",
    "{min_num}",
    "--max_num",
    "{max_num}",
    "--num_proc",
    "{num_proc}",
    "--text_key",
    "{text_key}"
  ]
}