{
  "name": "DC2_SpaceCleaning",

  "version": "1.0.0",

  "description": "字符串空格清理工具。读取结构化数据文件（CSV、TSV、Excel等），检查所有字符串类型字段，删除字段值前后多余的空格，然后输出为相同格式的文件。",

  "language": "python",

  "script_path": "scripts/DC2_SpaceCleaning.py",

  "entrypoint": "python scripts/DC2_SpaceCleaning.py",

  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径（支持CSV/TSV/Excel等）"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径（清理后的文件）"
    }
  ],

  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "space_cleaned_output.csv",
      "description": "清理空格后的结构化数据文件"
    }
  ],

  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}"
  ]
}
