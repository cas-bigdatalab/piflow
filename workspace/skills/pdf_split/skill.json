{
  "name": "pdf_split",
  "version": "1.0.0",
  "description": "将PDF按指定页码范围拆分为独立的PDF文件。当用户需要拆分PDF文档时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_pdf_split.py",
  "entrypoint": "python scripts/run_pdf_split.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入PDF文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出PDF文件路径（多页时自动添加_pageN后缀）"
    },
    {
      "name": "pages",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "页码范围，如\"1-3,5\"（可选，默认全部页拆为单页）"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "default": "pdf_split_output",
      "description": "拆分后的PDF文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--pages",
    "{pages}"
  ]
}