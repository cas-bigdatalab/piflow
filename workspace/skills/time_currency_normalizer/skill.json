{
  "name": "time_currency_normalizer",
  "version": "1.0.0",
  "name_zh": "时间货币归一算子",
  "description": "时间/货币归一工具。读取结构化文本数据，将常见日期格式统一为YYYY-MM-DD，将$、€、¥/￥前缀金额转换为USD/EUR/CNY数值表达。当用户提到统一日期格式、标准化货币金额、清洗时间表述等需求时使用此skill。即使用户没有明确说出skill名，只要任务涉及日期或货币符号的归一化，就应该使用此skill。不负责汇率换算、时区转换或非前缀货币单位解析。",
  "tag": "清洗",
  "language": "python",
  "script_path": "scripts/run_time_currency_normalizer.py",
  "entrypoint": "python scripts/run_time_currency_normalizer.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "text_columns",
      "role": "config",
      "type": "string",
      "required": false,
      "description": "处理的文本列，逗号分隔；默认全部字符串列"
    },
    {
      "name": "disable_date",
      "role": "config",
      "type": "string",
      "required": false,
      "default": "False",
      "description": "关闭日期归一，仅保留货币归一"
    },
    {
      "name": "disable_currency",
      "role": "config",
      "type": "string",
      "required": false,
      "default": "False",
      "description": "关闭货币归一，仅保留日期归一"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "default": "time_currency_normalizer_output.csv",
      "description": "归一化后的文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--text_columns",
    "{text_columns}",
    "--disable_date",
    "{disable_date}",
    "--disable_currency",
    "{disable_currency}"
  ]
}
