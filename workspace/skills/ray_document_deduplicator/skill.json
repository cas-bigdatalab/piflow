{
  "name": "ray_document_deduplicator",
  "version": "1.0.0",
  "description": "Ray分布式文档去重工具。使用精确匹配（MD5哈希）在文档级别删除重复的样本，基于Ray分布式框架。 当用户提到文档去重、删除重复文档、样本去重、分布式去重、大规模数据去重等需求时使用此skill。 即使用户没有明确说出\"Ray\"或\"分布式\"，只要任务涉及大规模文档去重处理， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_ray_document_deduplicator.py",
  "entrypoint": "python scripts/run_ray_document_deduplicator.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "lowercase",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否将文本转为小写进行比对",
      "default": false
    },
    {
      "name": "ignore_non_character",
      "role": "data",
      "type": "bool",
      "required": false,
      "description": "是否忽略非字母字符（空格、数字、标点）",
      "default": false
    },
    {
      "name": "backend",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "分布式后端类型（ray_actor/redis）",
      "default": "ray_actor"
    },
    {
      "name": "redis_address",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "Redis服务器地址",
      "default": "redis://localhost:6379"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "ray_document_deduplicator_output.jsonl",
      "description": "去重后的JSON文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--lowercase",
    "{lowercase}",
    "--ignore_non_character",
    "{ignore_non_character}",
    "--backend",
    "{backend}",
    "--redis_address",
    "{redis_address}",
    "--text_key",
    "{text_key}"
  ]
}