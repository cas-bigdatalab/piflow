{
  "name": "ray_image_deduplicator",
  "version": "1.0.0",
  "description": "Ray分布式图像去重工具。使用图像哈希精确匹配在文档级别删除重复样本，基于Ray分布式框架。 当用户提到图像去重、删除重复图片、分布式去重、大规模图像去重等需求时使用此skill。 即使用户没有明确说出\"Ray\"或\"分布式\"，只要任务涉及大规模图像去重处理， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_ray_image_deduplicator.py",
  "entrypoint": "python scripts/run_ray_image_deduplicator.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "method",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "图像哈希方法（phash/dhash/whash/ahash）",
      "default": "phash"
    },
    {
      "name": "backend",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "分布式后端类型（ray_actor/redis）",
      "default": "ray_actor"
    },
    {
      "name": "redis_address",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "Redis服务器地址",
      "default": "redis://localhost:6379"
    },
    {
      "name": "image_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "图像字段的键名",
      "default": "images"
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "ray_image_deduplicator_output.jsonl",
      "description": "去重后的JSON文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--method",
    "{method}",
    "--backend",
    "{backend}",
    "--redis_address",
    "{redis_address}",
    "--image_key",
    "{image_key}",
    "--text_key",
    "{text_key}"
  ]
}