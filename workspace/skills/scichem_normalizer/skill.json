{
  "name": "scichem_normalizer",
  "version": "1.0.0",
  "description": "科学公式/化学式规整：统一符号（+−×÷）、上下标、反应箭头和空格。",
  "tag": "清洗",
  "language": "python",
  "script_path": "scripts/scichem_normalizer.py",
  "entrypoint": "python scripts/scichem_normalizer.py",
  "input_params": [
    {"name": "input_path", "role": "input_data", "type": "string", "required": true, "description": "输入文件路径"},
    {"name": "output_path", "role": "output_data", "type": "string", "required": true, "description": "输出文件路径"},
    {"name": "text_columns", "role": "config", "type": "string", "required": false, "description": "处理的文本列，逗号分隔；默认全部字符串列"}
  ],
  "output_params": [
    {"name": "output_path", "role": "output_data", "type": "string", "required": true, "default": "scichem_normalizer_output.csv", "description": "规整后的文件"}
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--text_columns",
    "{text_columns}"
  ]
}
