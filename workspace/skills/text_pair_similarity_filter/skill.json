{
  "name": "text_pair_similarity_filter",
  "version": "1.0.0",
  "description": "文本对相似度过滤器。过滤器将文本之间具有相似性的文本对保留在特定范围内。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到文本对相似度过滤、文本对过滤、双文本相似度、文本配对过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_text_pair_similarity_filter.py",
  "entrypoint": "python scripts/run_text_pair_similarity_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "text_key_second",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "第二个文本字段名"
    },
    {
      "name": "hf_clip",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "HuggingFace上的CLIP模型",
      "default": "openai/clip-vit-base-patch32"
    },
    {
      "name": "min_score",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小相似度分数",
      "default": 0.1
    },
    {
      "name": "max_score",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大相似度分数",
      "default": 1.0
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any 或 all）",
      "default": "any"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "text_pair_similarity_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--text_key_second",
    "{text_key_second}",
    "--hf_clip",
    "{hf_clip}",
    "--min_score",
    "{min_score}",
    "--max_score",
    "{max_score}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}