{
  "name": "key_value_grouper",
  "version": "1.0.0",
  "description": "根据给定键中的值将样本分组为批处理样本。当用户提到样本分组、按键值分组、批处理样本、按键聚合、分组聚合等需求时使用此skill。 即使用户没有明确说出\"分组\"，只要任务涉及将多个样本按某个字段/键的值进行归类合并，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_key_value_grouper.py",
  "entrypoint": "python scripts/run_key_value_grouper.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "group_by_keys",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "分组键，逗号分隔，支持嵌套键如 \"meta.language\"",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "json_file",
      "default": "key_value_grouper_output.json",
      "description": "分组后的JSON文件，每组样本的字段值为数组"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--group_by_keys",
    "{group_by_keys}"
  ]
}