{
  "name": "QC3_NumericDataThresholdCheck",
  "version": "1.0.0",
  "description": "数值数据阈值检验工具。读取结构化数据文件（CSV、TSV、Excel等），检查数值字段是否在指定的门限范围内，不允许超出门限值之外，最后输出为同格式的文件。当用户需要对数据进行阈值检验、数值范围检查、数据质量控制等操作时使用此skill。",
  "language": "python",
  "script_path": "scripts/QC3_NumericDataThresholdCheck.py",
  "entrypoint": "python scripts/QC3_NumericDataThresholdCheck.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "origin_output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径（与输入文件格式相同）"
    },
    {
      "name": "field_name",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "要检查的字段名"
    },
    {
      "name": "max_value",
      "role": "data",
      "type": "float",
      "required": true,
      "description": "最大值"
    },
    {
      "name": "min_value",
      "role": "data",
      "type": "float",
      "required": true,
      "description": "最小值"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "QC标记"
    },
    {
      "name": "error_output_path",
      "role": "output_data",
      "type": "string",
      "required": false,
      "description": "错误数据输出文件路径"
    },
    {
      "name": "additional_condition",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "额外条件"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "标记字段名",
      "default": "QC0000"
    },
    {
      "name": "id_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "ID字段名",
      "default": "ID0000"
    }
  ],
  "output_params": [
    {
      "name": "origin_output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC3_NumericDataThresholdCheck_output.csv",
      "description": "阈值检验后的结构化数据文件，带质控标记"
    },
    {
      "name": "error_output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC3_NumericDataThresholdCheck_output.csv",
      "description": "错误数据文件（可选），包含超出阈值范围的记录"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--origin_output_path",
    "{origin_output_path}",
    "--field_name",
    "{field_name}",
    "--max_value",
    "{max_value}",
    "--min_value",
    "{min_value}",
    "--qc_mark",
    "{qc_mark}",
    "--error_output_path",
    "{error_output_path}",
    "--additional_condition",
    "{additional_condition}",
    "--mark_field_name",
    "{mark_field_name}",
    "--id_field_name",
    "{id_field_name}"
  ]
}