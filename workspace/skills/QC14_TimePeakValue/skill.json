{
  "name": "QC14_TimePeakValue",
  "version": "1.0.0",
  "description": "尖峰检验（连续剧烈变化检测）工具。读取时间序列数据，识别在连续N次的相邻读数之间的差值（变化量）的绝对值都高于预设阈值的异常数据，最后输出为相同格式的文件。 当用户提到尖峰检验、连续剧烈变化检测、峰值检测、时间序列突变检查等需求时使用此skill。 即使用户没有说出\"尖峰检验\"，只要任务涉及检查时间序列数据的剧烈变化，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/QC14_TimePeakValue.py",
  "entrypoint": "python scripts/QC14_TimePeakValue.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "conditions",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "检验条件，格式：字段名,峰值阈值,连续次数，多行用换行分隔"
    },
    {
      "name": "time_field",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间字段名（用于排序判断连续性）"
    },
    {
      "name": "time_format",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "时间格式（如：%Y-%m-%d %H:%M:%S）"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识",
      "default": "尖值异常"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识字段名",
      "default": "QC0000"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC14_TimePeakValue_output.csv",
      "description": "尖峰检验后的结构化数据文件，带质控标识"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--conditions",
    "{conditions}",
    "--time_field",
    "{time_field}",
    "--time_format",
    "{time_format}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}