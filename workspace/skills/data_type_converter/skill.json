{
  "name": "data_type_converter",
  "version": "1.0.0",
  "description": "数据类型转换工具。转换数据字段的类型，支持数值、字符串、日期等类型互转。当用户提到类型转换、数据格式转换等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_data_type_converter.py",
  "entrypoint": "python scripts/run_data_type_converter.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "conversions",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "转换规则，格式：字段名:目标类型，多个用逗号分隔"
    },
    {
      "name": "date_format",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "日期格式（用于日期类型转换）",
      "default": "%Y-%m-%d"
    },
    {
      "name": "errors",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "错误处理方式（raise/coerce/ignore）",
      "default": "coerce"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "csv_file",
      "default": "data_type_converter_output.csv",
      "description": "转换后的数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--conversions",
    "{conversions}",
    "--date_format",
    "{date_format}",
    "--errors",
    "{errors}"
  ],
  "tag": "格式转换"
}