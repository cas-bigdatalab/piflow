{
  "name": "text_entity_dependency_filter",
  "version": "1.0.0",
  "description": "文本实体依赖过滤器。识别文本中与其他令牌独立的实体，并对其进行过滤。 本SKILL使用依赖data_juicer，请在调用前安装好python环境并安装data_juicer，你可用以下指令进行安装： pip install py-data-juicer  当用户提到实体依赖过滤、文本实体检测、依存关系过滤、实体独立性过滤等需求时使用此skill。",
  "language": "python",
  "script_path": "scripts/run_text_entity_dependency_filter.py",
  "entrypoint": "python scripts/run_text_entity_dependency_filter.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入数据文件路径 (JSON/JSONL格式)"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出数据文件路径 (JSONL格式)"
    },
    {
      "name": "lang",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "语言代码（en 或 zh）",
      "default": "en"
    },
    {
      "name": "min_dependency_num",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "最小依赖边数",
      "default": 1
    },
    {
      "name": "any_or_all",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "过滤策略（any 或 all）",
      "default": "all"
    },
    {
      "name": "num_proc",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "并行处理的进程数",
      "default": 1
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "jsonl_file",
      "default": "text_entity_dependency_filter_output.jsonl",
      "description": "过滤后的JSONL格式数据文件"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--lang",
    "{lang}",
    "--min_dependency_num",
    "{min_dependency_num}",
    "--any_or_all",
    "{any_or_all}",
    "--num_proc",
    "{num_proc}"
  ]
}