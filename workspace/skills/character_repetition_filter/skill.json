{
  "name": "character_repetition_filter",
  "version": "1.0.0",
  "description": "字符重复比例过滤器。过滤文本中字符级n-gram重复比例不在指定范围内的样本。 当用户提到字符重复、重复比例过滤、文本重复过滤、清理重复内容等需求时使用此skill。 即使用户没有明确说出\"字符重复\"，只要任务涉及根据文本中字符重复的程度来筛选数据， 就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/run_character_repetition_filter.py",
  "entrypoint": "python scripts/run_character_repetition_filter.py",
  "input_params": [
    {
      "name": "input",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入JSON文件路径"
    },
    {
      "name": "output",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出JSON文件路径"
    },
    {
      "name": "rep_len",
      "role": "data",
      "type": "int",
      "required": false,
      "description": "字符级n-gram重复长度",
      "default": 10
    },
    {
      "name": "min_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最小重复比例",
      "default": 0.0
    },
    {
      "name": "max_ratio",
      "role": "data",
      "type": "float",
      "required": false,
      "description": "最大重复比例",
      "default": 0.5
    },
    {
      "name": "text_key",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "文本字段的键名",
      "default": "text"
    }
  ],
  "output_params": [
    {
      "name": "output",
      "role": "output_data",
      "type": "json_file",
      "default": "character_repetition_filter_output.json",
      "description": "过滤后的JSON文件，包含字符重复比例在指定范围内的样本"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input",
    "{input}",
    "--output",
    "{output}",
    "--rep_len",
    "{rep_len}",
    "--min_ratio",
    "{min_ratio}",
    "--max_ratio",
    "{max_ratio}",
    "--text_key",
    "{text_key}"
  ]
}