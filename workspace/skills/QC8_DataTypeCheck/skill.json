{
  "name": "QC8_DataTypeCheck",
  "version": "1.0.0",
  "description": "数据类型检查工具。读取被检验表，检查指定数值型字段的数据类型是否正确（是否能转换为数值型）， 并标记不合格的数据点，最后输出为相同格式的文件。 当用户提到数据类型检查、数值类型校验、字段类型检查、数据格式校验等需求时使用此skill。 即使用户没有说出\"数据类型检查\"，只要任务涉及检查数据字段类型是否正确，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/QC8_DataTypeCheck.py",
  "entrypoint": "python scripts/QC8_DataTypeCheck.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "check_fields_name",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "检查字段名，逗号分隔（如：field1,field2）"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "质控标识"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识字段名",
      "default": "QC0000"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC8_DataTypeCheck_output.csv",
      "description": "数据类型检查后的结构化数据文件，带质控标识"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--check_fields_name",
    "{check_fields_name}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}