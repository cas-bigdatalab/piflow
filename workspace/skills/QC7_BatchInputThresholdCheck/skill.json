{
  "name": "QC7_BatchInputThresholdCheck",
  "version": "1.0.0",
  "description": "批量阈值检验-输入框工具。读取被检验表，将数据列的值与输入阈值条件中定义的上下限进行比对， 识别并标记超出允许范围（包括上限和下限）或为空值的数据点，最后输出为相同格式的文件。 当用户提到批量阈值检验、输入框阈值检验、多字段阈值检查、范围校验等需求时使用此skill。 即使用户没有明确说出\"批量阈值输入框\"，只要任务涉及根据输入的阈值条件进行批量范围校验，就应该使用此skill。",
  "language": "python",
  "script_path": "scripts/QC7_BatchInputThresholdCheck.py",
  "entrypoint": "python scripts/QC7_BatchInputThresholdCheck.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件路径"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件路径"
    },
    {
      "name": "conditions",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "阈值条件，格式：字段名,最大值,最小值，多行用换行分隔"
    },
    {
      "name": "qc_mark",
      "role": "data",
      "type": "string",
      "required": true,
      "description": "质控标识"
    },
    {
      "name": "mark_field_name",
      "role": "data",
      "type": "string",
      "required": false,
      "description": "质控标识字段名",
      "default": "QC0000"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "csv_file",
      "default": "QC7_BatchInputThresholdCheck_output.csv",
      "description": "批量阈值检验后的结构化数据文件，带质控标识"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--conditions",
    "{conditions}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}