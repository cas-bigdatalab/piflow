{
  "name": "unique_constraint_check",
  "version": "1.0.0",
  "description": "唯一性约束校验：检查指定字段的值是否在全表中唯一，标记重复出现的值所在行，首次出现的行视为保留。",
  "tag": "校验",
  "language": "python",
  "script_path": "scripts/unique_constraint_check.py",
  "entrypoint": "python scripts/unique_constraint_check.py",
  "input_params": [
    {
      "name": "input_path",
      "role": "input_data",
      "type": "string",
      "required": true,
      "description": "输入文件"
    },
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "输出文件"
    },
    {
      "name": "unique_fields",
      "role": "config",
      "type": "string",
      "required": true,
      "description": "唯一性字段，逗号分隔（每个字段分别检查，如 id 或 name,email）"
    },
    {
      "name": "allow_null",
      "role": "config",
      "type": "string",
      "required": false,
      "description": "允许多个空值（默认关闭，开启后空值不视为重复）",
      "default": "False"
    },
    {
      "name": "qc_mark",
      "role": "config",
      "type": "string",
      "required": true,
      "description": "质控标识"
    },
    {
      "name": "mark_field_name",
      "role": "config",
      "type": "string",
      "required": false,
      "description": "质控标识字段名（默认QC0000）"
    }
  ],
  "output_params": [
    {
      "name": "output_path",
      "role": "output_data",
      "type": "string",
      "required": true,
      "description": "带质控标识的输出",
      "default": "unique_constraint_check_output_path.csv"
    }
  ],
  "command_template": [
    "python",
    "{script_path}",
    "--input_path",
    "{input_path}",
    "--output_path",
    "{output_path}",
    "--unique_fields",
    "{unique_fields}",
    "--allow_null",
    "{allow_null}",
    "--qc_mark",
    "{qc_mark}",
    "--mark_field_name",
    "{mark_field_name}"
  ]
}
